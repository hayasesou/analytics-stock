# Shared
APP_ENV=development
TZ=Asia/Tokyo
WEB_BASE_URL=https://your-project.vercel.app
PORT=3000

# Secrets
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
LLM_SECURITY_REPORTS_ENABLED=0
LLM_WEEKLY_SUMMARY_ENABLED=0
LLM_SECURITY_REPORT_TIMEOUT_SEC=12
LLM_WEEKLY_SUMMARY_TIMEOUT_SEC=12
LLM_SECURITY_REPORT_MAX_OUTPUT_TOKENS=750
LLM_WEEKLY_SUMMARY_MAX_OUTPUT_TOKENS=600
LLM_SECURITY_REPORT_MAX_CALLS=20
LLM_SECURITY_REPORT_MAX_CONSECUTIVE_FAILURES=3
LLM_SECURITY_REPORT_BUDGET_SEC=180
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# Basic auth (Web)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# Neon
NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_EVIDENCE=stock-analysis-evidence
R2_BUCKET_DATA=stock-analysis-data
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Data sources
JQUANTS_API_KEY=
JQUANTS_EMAIL=
JQUANTS_PASSWORD=
MASSIVE_API_KEY=
EDINET_API_KEY=
SEC_USER_AGENT=stock-analysis (contact: hayasesou3@gmail.com)
YOUTUBE_API_KEY=

# Optional FX source (FRED)
FRED_API_KEY=

# Worker budget
LLM_MONTHLY_BUDGET_USD=50

# Deep research import (optional)
DEEP_RESEARCH_REPORT_PATH=
DEEP_RESEARCH_SECURITY_ID=

# Crypto gateway (executor -> gateway)
CRYPTO_GATEWAY_URL=http://gateway-crypto:8080
CRYPTO_GATEWAY_AUTH_TOKEN=
CRYPTO_GATEWAY_DRY_RUN=1
CRYPTO_GATEWAY_HTTP_TIMEOUT_SEC=5
BINANCE_LIVE_ENABLED=0
HYPERLIQUID_LIVE_ENABLED=0
GATEWAY_BINANCE_API_KEY=
GATEWAY_BINANCE_API_SECRET=

# JP gateway (executor -> gateway_jp -> kabu station)
JP_GATEWAY_URL=http://gateway-jp:8081
JP_GATEWAY_AUTH_TOKEN=
JP_GATEWAY_DRY_RUN=1
JP_GATEWAY_HTTP_TIMEOUT_SEC=5
JP_GATEWAY_MAX_RETRIES=2
JP_GATEWAY_RETRY_SLEEP_SEC=0.25
JP_GATEWAY_RATE_LIMIT_PER_SEC=5
JP_GATEWAY_PER_SYMBOL_LIMIT_PER_SEC=5
JP_GATEWAY_WAIT_TIMEOUT_SEC=2
KABU_STATION_BASE_URL=http://host.docker.internal:18080/kabusapi
KABU_STATION_API_PASSWORD=
KABU_STATION_API_TOKEN=

# US gateway (executor -> gateway_us -> IBKR)
US_GATEWAY_URL=http://gateway-us:8090
US_GATEWAY_AUTH_TOKEN=
US_GATEWAY_DRY_RUN=1
IBKR_LIVE_ENABLED=0
IBKR_HOST=host.docker.internal
IBKR_PORT=4002
IBKR_CLIENT_ID=1301
IBKR_ACCOUNT_ID=
IBKR_CONNECT_TIMEOUT_SEC=5
IBKR_RECONNECT_ATTEMPTS=3
IBKR_RECONNECT_BACKOFF_SEC=1
